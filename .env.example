# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hub:hub_local_pass@localhost:5432/hub_billing
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=hub_billing:

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_isso_em_producao_use_openssl_rand_base64_64
JWT_EXPIRY=8h
REFRESH_TOKEN_EXPIRY=30d

# ─── Gateways ─────────────────────────────────────────────────────────────────

# Asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_SECRET=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Em produção: https://api.asaas.com/v3

# Stripe (fase 3)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── Filas ────────────────────────────────────────────────────────────────────
WEBHOOK_QUEUE_CONCURRENCY=5
INTERNAL_EVENTS_QUEUE_CONCURRENCY=3
LICENSE_EXPIRY_CRON=0 2 * * *   # Roda às 2h da manhã

# ─── Notificações ─────────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@seuhub.com.br

# ─── Observabilidade ──────────────────────────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=info
